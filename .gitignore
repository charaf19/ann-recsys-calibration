# ---- Python ----
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# ---- Virtual environments ----
.venv/
venv/

# ---- IDEs / OS ----
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ---- Datasets, embeddings, indexes (never committed) ----
data/

# ---- Logs, archives, temporary files ----
*.log
*.zip
*.tmp
*.bak

# ---- Heavy generated evidence (regenerable; small text evidence stays) ----
# per-query metric arrays (large .npz, bootstrap inputs)
results/main/perquery/*
!results/main/perquery/.gitkeep
# rendered figures (regenerated by figures_paper.py)
results/paper/figures/*.png
results/paper/figures/*.pdf

# Retained on purpose (explicitly NOT ignored):
#   results/**/.gitkeep         directory scaffold
#   results/**/*.csv            small CSV evidence
#   results/**/*.json           JSON metadata / provenance sidecars
#   results/**/*.md             Markdown reports
#   results/**/*.tex            LaTeX tables
#   configs/*.yml               configuration files
