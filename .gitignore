# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual Environment
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Data files (large datasets)
data/
*.csv
*.tsv
*.parquet
*.feather

# Exception: keep small metadata/config CSVs in results
!results/**/*.csv
!results/*.csv

# Model files and embeddings
*.npy
*.index
*.pkl
*.h5
*.pt
*.pth

# Logs
*.log

# Results and outputs
# Policy: small text outputs under results/ (csv, md, json, tex) stay
# trackable; heavy binary artifacts (figures, per-query arrays) are ignored,
# but the directory scaffold is kept via .gitkeep files.
results/runs/
results/figures/*
!results/figures/.gitkeep
results/figures_paper/*
!results/figures_paper/.gitkeep
results/main/perquery/*
!results/main/perquery/.gitkeep

# Per-query metric arrays and other large numpy archives
*.npz

# Temporary files
*.tmp
*.bak
*.cache
